{
    "name": "SpessaSynth",
    "version": "4.2.12",
    "type": "module",
    "private": true,
    "scripts": {
        "perms": "chmod +x src/build/*",
        "test:types": "eslint --cache && tsc -b",
        "start": "node src/build/start.ts",
        "build": "npm run test:types && npm run build:fast",
        "build:fast": "node src/build/build.ts",
        "debug": "src/build/enable_debug.sh",
        "release": "src/build/disable_debug.sh",
        "clean": "rm -rf dist; rm -rf local-dev; rm -rf server"
    },
    "devDependencies": {
        "@chialab/esbuild-plugin-meta-url": "^0.19.1",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "prettier --write",
            "eslint --cache --fix"
        ],
        "*.{html,json,md,yml,yaml,css}": "prettier --write"
    },
    "dependencies": {
        "jszip": "^3.10.1",
        "spessasynth_core": "file:../spessasynth_core",
        "spessasynth_lib": "file:../spessasynth_lib"
    }
}
